# Production Environment Variables Example
# Copy this to .env and update with your real values

# Flask Settings
SECRET_KEY=yoursecretkey123
FLASK_ENV=production
FLASK_APP=run.py

# Database Configuration (MySQL)
# If using a single connection string:
DATABASE_URL=mysql+pymysql://user:pass@host:port/dbname

# Or individual parameters (if using a local MySQL):
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smart_inventory

# Security
JWT_SECRET_KEY=jwt-secret-placeholder
